# Backend
PORT=5001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Neon / PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DB_SSL=true

# Security - change before production
JWT_SECRET=change_this_to_a_long_random_secret
OTP_PEPPER=change_this_to_another_random_secret
TOKEN_EXPIRES_IN=12h

# First Super Admin seed
ADMIN_CODE=admin
ADMIN_PASSWORD=admin123
ADMIN_WHATSAPP=60123456789
ANNUAL_FEE_AMOUNT=100
SEED_DEMO_DATA=true

# Real TAC email. Use either Resend OR SMTP.
# RESEND_API_KEY=re_xxx
EMAIL_FROM=no-reply@yourdomain.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email
# SMTP_PASS=your_app_password

# Annual fee auto renewal cron. Default daily 00:10 server time.
ENABLE_ANNUAL_FEE_CRON=true
ANNUAL_FEE_CRON=10 0 * * *

# Keep disabled in production
ENABLE_DEV_RESET=false
